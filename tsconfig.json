{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "outDir": "dist",
    "types": ["vite/client", "node", "unplugin-info/client"],
    "noEmit": true,
    "paths": {
      "@/*": ["./src/renderer/*"]
    }
  },
  "include": ["src", "tests", "forge.config.ts", "forge.env.d.ts", "vite.*.config.ts", "vitest.config.ts"],
  "//exclude": "These outbound/DM integration tests call old ProtocolSession methods the new SessionAdapter does not expose; they are re-harnessed onto makeTestSession in Phase G (Task G2). Excluded from typecheck until then.",
  "exclude": [
    "tests/integration/inbound/dm-send-ack.test.ts",
    "tests/integration/outbound/contact-interop.test.ts",
    "tests/integration/outbound/device-admin.test.ts",
    "tests/integration/outbound/device-time.test.ts",
    "tests/integration/outbound/flood-scope.test.ts",
    "tests/integration/outbound/misc.test.ts",
    "tests/integration/outbound/path-diagnostics.test.ts",
    "tests/integration/outbound/raw-data.test.ts",
    "tests/integration/outbound/signing.test.ts",
    "tests/integration/outbound/tuning.test.ts"
  ]
}
