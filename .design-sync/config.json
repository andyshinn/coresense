    "Label": "src/renderer/components/ui/label.tsx",
    "Popover": "src/renderer/components/ui/popover.tsx",
    "Progress": "src/renderer/components/ui/progress.tsx",
    "Select": "src/renderer/components/ui/select.tsx",
    "Separator": "src/renderer/components/ui/separator.tsx",
    "Sheet": "src/renderer/components/ui/sheet.tsx",
    "Sidebar": "src/renderer/components/ui/sidebar.tsx",
    "Skeleton": "src/renderer/components/ui/skeleton.tsx",
    "Slider": "src/renderer/components/ui/slider.tsx",
    "Switch": "src/renderer/components/ui/switch.tsx",
    "Toaster": "src/renderer/components/ui/sonner.tsx",
    "Toggle": "src/renderer/components/ui/toggle.tsx",
